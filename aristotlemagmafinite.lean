/-
If a finite magma satisfies (A), then it is left cancellative.
-/
def PropA (M : Type*) [Mul M] : Prop := ∀ x y : M, x = y * (x * ((y * x) * y))
def PropB (M : Type*) [Mul M] : Prop := ∀ x : M, x = ((x * x) * x) * x
theorem left_cancellative_of_PropA {M : Type*} [Mul M] [Finite M] (h : PropA M) :
  ∀ c x y : M, c * x = c * y → x = y := by
    intro c x y hxy;
    -- For any fixed y, the map L_y : x ↦ y * x is surjective because for any x, x = y * (x * ((y * x) * y)).
    have h_surjective : ∀ y : M, Function.Surjective (fun x => y * x) := by
      intro y x
      obtain ⟨z, hz⟩ : ∃ z : M, x = y * z := by
        exact ⟨ _, h x y ⟩;
      exact ⟨ z, hz.symm ⟩;
    exact Finite.injective_iff_surjective.mpr ( h_surjective c ) hxy
