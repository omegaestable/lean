def findCounterexampleSize4 : Option (Fin 4 → Fin 4 → Fin 4) :=
  let n := 4
  let range := List.finRange n
  let perms := (List.permutations range)
  -- We need 4 rows, each is a permutation.
  -- There are 24^4 = 331,776 candidates.
  let candidates := List.replicate n perms |> List.mapM id
  let toTable (rows : List (List (Fin 4))) : Fin 4 → Fin 4 → Fin 4 :=
    fun i j => (rows.get! i.val).get! j.val
  candidates.findSome? fun rows =>
    let mul := toTable rows
    -- Check (A): x = y * (x * ((y * x) * y))
    let checkA := range.all fun x => range.all fun y =>
      x == mul y (mul x (mul (mul y x) y))
    if checkA then
      -- Check (B): x = ((x * x) * x) * x
      let checkB := range.all fun x =>
        x == mul (mul (mul x x) x) x
      if !checkB then some mul else none
    else none
