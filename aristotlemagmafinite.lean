/-
Define the inverse of left multiplication and prove it is a two-sided inverse.
-/
def inv_L {M : Type*} [Mul M] (y : M) (x : M) : M := x * ((y * x) * y)
theorem inv_L_is_right_inverse {M : Type*} [Mul M] (h : PropA M) (y : M) :
  Function.RightInverse (inv_L y) (HMul.hMul y) := by
  intro x
  exact (h x y).symm
theorem inv_L_is_left_inverse {M : Type*} [Mul M] [Finite M] (h : PropA M) (y : M) :
  Function.LeftInverse (inv_L y) (HMul.hMul y) := by
  have h_surj : Function.Surjective (HMul.hMul y) :=
    Function.RightInverse.surjective (inv_L_is_right_inverse h y)
  have h_inj : Function.Injective (HMul.hMul y) :=
    Finite.injective_iff_surjective.mpr h_surj
  exact Function.RightInverse.leftInverse_of_injective (inv_L_is_right_inverse h y) h_inj
/-
Define L_perm.
-/
noncomputable def L_perm {M : Type*} [Mul M] [Finite M] (h : PropA M) (x : M) : Equiv.Perm M :=
  Equiv.ofBijective (fun z => x * z) (by
    have h_inj : Function.Injective (fun z => x * z) := left_cancellative_of_PropA h x
    have h_surj : Function.Surjective (fun z => x * z) := Finite.injective_iff_surjective.mp h_inj
    exact ⟨h_inj, h_surj⟩
  )
theorem L_perm_apply {M : Type*} [Mul M] [Finite M] (h : PropA M) (x y : M) :
  L_perm h x y = x * y := rfl
